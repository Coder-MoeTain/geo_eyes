# =============================================================================
# GeoEye-AI example environment configuration
# Copy to `.env` and adjust for your environment.
#
# IMPORTANT:
# - Do NOT commit real secrets in `.env`.
# - In production, inject secrets via your deploy system/secret manager.
# =============================================================================

# -----------------------------
# Runtime environment
# -----------------------------
# development | staging | production
ENV=development

# -----------------------------
# Backend auth / security
# -----------------------------
# REQUIRED in non-development. Must not be "change-me".
JWT_SECRET=change-me

# Enables bootstrapping an admin user at API startup (only if all DEFAULT_ADMIN_* are set).
DEFAULT_ADMIN_ENABLED=false
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=

# CORS configuration (JSON string).
# If CORS_ALLOW_CREDENTIALS=true, do NOT use "*" in production.
CORS_ALLOWED_ORIGINS_JSON=["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ALLOW_CREDENTIALS=true

# Cookie security (recommended for production when served over HTTPS)
SECURE_COOKIES=false
# lax | strict | none
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# Signed upload tokens (optional but recommended for signed upload flow)
SIGNED_UPLOAD_SECRET=
SIGNED_UPLOAD_EXPIRE_MINUTES=15

# -----------------------------
# Database (used by docker-compose + backend)
# -----------------------------
POSTGRES_USER=geoeye
POSTGRES_PASSWORD=geoeye
POSTGRES_DB=geoeye
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Optional: override full SQLAlchemy URL.
# DATABASE_URL=postgresql+psycopg2://geoeye:geoeye@postgres:5432/geoeye

# -----------------------------
# Redis / Celery
# -----------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------
# Geo / tiles
# -----------------------------
PUBLIC_TITILER_URL=http://localhost/titiler
INTERNAL_TITILER_URL=http://titiler:8000
TITILER_BASE_URL=http://titiler:8000

# -----------------------------
# Uploads / limits
# -----------------------------
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=256

# -----------------------------
# ML / models
# -----------------------------
YOLO_MODEL_PATH=/models/yolov8-aircraft.pt
# "0", "cuda:0", or "cpu"
YOLO_DEVICE=0
DETECTION_THRESHOLDS_JSON={"aircraft":0.25,"large_aircraft":0.3,"cargo_aircraft":0.35}

# Optional / auxiliary models
SAM_MODEL_PATH=/models/sam_vit_h_4b8939.pth

# -----------------------------
# STAC (coordinate-based acquisition)
# -----------------------------
STAC_API_URL=https://earth-search.aws.element84.com/v1

# -----------------------------
# Frontend (Vite)
# -----------------------------
VITE_API_BASE_URL=http://localhost:8000

